# HH Applicant Tool — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# === Supabase (required for dashboard mode) ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# === Dashboard Auth ===
DASHBOARD_SECRET=change-me-to-a-strong-password

# === HH.ru Profile (optional, for multi-profile support) ===
# HH_PROFILE_ID=default

# === Telegram Notifications (optional) ===
# TG_BOT_TOKEN=your-telegram-bot-token
# TG_CHAT_ID=your-chat-id

# === Config directory (default: ~/.config/hh-applicant-tool) ===
# CONFIG_DIR=./config
